#include <zephyr/dt-bindings/gpio/gpio.h>
#include "urchin.dtsi"

/ {
    kscan: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        status = "disabled"; // Dongle has no matrix; prevent phantom presses (e.g. stuck Q)
        row-gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
        col-gpios = <&gpio0 0 GPIO_ACTIVE_LOW>;
    };
};
